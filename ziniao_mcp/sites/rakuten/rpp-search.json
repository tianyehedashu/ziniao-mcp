{
  "name": "Rakuten RPP Search Report",
  "description": "RPP 広告レポート検索（日別）- 利用ページのログイン状態で API を呼び出す",
  "auth": {
    "type": "xsrf",
    "hint": "需先在当前浏览器标签页登录 RMS（ad.rms.rakuten.co.jp）；请求会携带 Cookie 并从 Cookie 注入 X-XSRF-TOKEN"
  },
  "pagination": {
    "type": "body_field",
    "page_field": "page",
    "total_field": "data.totalPage",
    "start": 1,
    "max_pages": 500,
    "merge_items_field": "data.rppReports"
  },
  "navigate_url": "https://ad.rms.rakuten.co.jp/rpp/reports",
  "mode": "fetch",
  "url": "https://ad.rms.rakuten.co.jp/rpp/api/reports/search",
  "method": "POST",
  "headers": {
    "Accept": "application/json",
    "Accept-Language": "ja",
    "Content-Type": "application/json"
  },
  "xsrf_cookie": "XSRF-TOKEN",
  "vars": {
    "start_date": {
      "type": "str",
      "required": true,
      "description": "開始日 (YYYY-MM-DD)",
      "example": "2026-03-01"
    },
    "end_date": {
      "type": "str",
      "required": true,
      "description": "終了日 (YYYY-MM-DD)",
      "example": "2026-03-07"
    },
    "page": {
      "type": "int",
      "default": 1,
      "description": "ページ番号"
    },
    "selection_type": {
      "type": "int",
      "default": 1,
      "description": "集計単位: 1=日別, 2=キャンペーン, 3=商品, 4=キーワード"
    },
    "campaign_type": {
      "type": "str",
      "default": "1",
      "description": "キャンペーンタイプ: 1=通常"
    }
  },
  "body": {
    "page": "{{page}}",
    "selectionType": "{{selection_type}}",
    "periodType": 2,
    "startDate": "{{start_date}}",
    "endDate": "{{end_date}}",
    "reportFilter": 1,
    "campaignType": "{{campaign_type}}",
    "rankType": 1,
    "allUsers": true,
    "newUsers": true,
    "existingUsers": true,
    "noOfClicks": true,
    "adsalesBefore": true,
    "cpc": true,
    "h12": true,
    "h720": true,
    "gms": true,
    "roas": true,
    "cv": true,
    "cvr": true,
    "cpa": true
  }
}
