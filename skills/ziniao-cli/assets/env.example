# Copy to ~/.ziniao/.env (auto-loaded by CLI + daemon) or paste selected lines into Cursor MCP `env`.
# Prefer env vars for secrets so you never commit passwords to git.

# Ziniao store features (optional)
# ZINIAO_COMPANY=
# ZINIAO_USERNAME=
# ZINIAO_PASSWORD=
# ZINIAO_CLIENT_PATH=D:\path\to\ziniao.exe
# ZINIAO_SOCKET_PORT=16851
# ZINIAO_VERSION=v6

# Chrome (optional — path auto-detected if unset)
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# CHROME_USER_DATA=C:\Users\you\.ziniao\chrome-profile
# CHROME_CDP_PORT=0

# CLI output (optional — parity with AGENT_BROWSER_*)
# ZINIAO_JSON=1
# ZINIAO_CONTENT_BOUNDARIES=1
# ZINIAO_MAX_OUTPUT=8000
# ZINIAO_MAX_OUTPUT=0   # stdout 不截断（默认未设置时为 2000 字符终端保护）
