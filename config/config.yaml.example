ziniao:
  # 浏览器配置
  browser:
    # 浏览器版本 v5 或 v6
    version: v6
    # 浏览器客户端路径
    # Windows V5: starter.exe, V6: ziniao.exe
    # macOS: ziniao
    # Linux: /opt/ziniao/ziniaobrowser
    client_path: D:\ziniao\ziniao.exe
    # 与客户端通信的 HTTP 端口，需未被占用
    socket_port: 16851

  # 企业登录的用户信息
  user_info:
    company: 您登录紫鸟浏览器时输入的企业公司名
    username: 您登录紫鸟浏览器时输入的企业用户名
    password: 您登录紫鸟浏览器时输入的密码

  # CDP 反检测配置（可选）
  stealth:
    enabled: true
    js_patches: true
    human_behavior: true
    delay_range: [200, 800]
    typing_speed: [50, 150]
    mouse_movement: true

# Chrome 浏览器配置（可选，与紫鸟可同时使用）
# 也可通过环境变量配置：CHROME_EXECUTABLE_PATH, CHROME_CDP_PORT, CHROME_USER_DATA_DIR
chrome:
  # Chrome 可执行文件路径（留空则自动检测系统安装的 Chrome）
  executable_path: ""
  # 默认 CDP 远程调试端口（0 则每次自动分配空闲端口）
  default_cdp_port: 0
  # 用户数据目录（留空则使用 ~/.ziniao/chrome-profile，复用登录与状态）
  user_data_dir: ""
  # 是否以无头模式启动
  headless: false

# 强风控站点策略（可选）：与内置表合并；可覆盖 ``policy_hint`` 文案或新增主机。
# 文件发现顺序与 ``ziniao`` 其它配置一致：项目 ``config/config.yaml`` 与
# ``~/.ziniao/config.yaml`` fall-through 合并；命令行 ``--config`` 为单一来源。
site_policy:
  policies:
    # 示例：仅自定义提示（仍继承内置 shopee.* 的 default_mode / allow_* 字段）
    # shopee.com.my:
    #   policy_hint: "本环境请走 passive-open + chrome input，勿 connect。"
    # 示例：为内网或自研风控站追加一条
    # internal.example.com:
    #   default_mode: passive
    #   allow_runtime_attach: false
    #   allow_stealth: false
    #   allow_input_only: true
    #   policy_hint: "internal.example.com: 仅允许 passive 路径。"
